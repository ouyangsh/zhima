{
    "bsonType": "object",
    "required": [
        "post_id",
        "user_id",
        "content",
        "user_name"
    ],
    "permission": {
        "read": true,
        "create": "auth.uid != null",
        "update": "doc.user_id == auth.uid",
        "delete": "doc.user_id == auth.uid"
    },
    "properties": {
        "_id": {
            "description": "ID，系统自动生成"
        },
        "post_id": {
            "bsonType": "string",
            "description": "关联的作品ID"
        },
        "user_id": {
            "bsonType": "string",
            "description": "评论者ID"
        },
        "user_name": {
            "bsonType": "string",
            "description": "评论者昵称"
        },
        "user_avatar": {
            "bsonType": "string",
            "description": "评论者头像"
        },
        "content": {
            "bsonType": "string",
            "description": "评论内容"
        },
        "created_at": {
            "bsonType": "timestamp",
            "description": "创建时间",
            "defaultValue": {
                "$env": "now"
            }
        }
    }
}