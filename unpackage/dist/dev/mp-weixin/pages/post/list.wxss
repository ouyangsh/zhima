  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background-color: #ffffff;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
}
.post-list-page .nav-bar.data-v-bbac3d2e {
  height: 44px;
  padding: 0 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #ffffff;
  position: relative;
}
.post-list-page .nav-bar .title.data-v-bbac3d2e {
  font-size: 16px;
  font-weight: 600;
  color: #3A3A3A;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}
.post-list-page .nav-bar .left.data-v-bbac3d2e, .post-list-page .nav-bar .right.data-v-bbac3d2e {
  min-width: 24px;
